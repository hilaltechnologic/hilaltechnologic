---
// Lazy Analytics Component
// Load analytics only after user interaction to reduce initial HTML

import { SITE_CONFIG } from '../config/site';

interface Props {
  enableGA?: boolean;
  enableGTM?: boolean;
  loadOnScroll?: boolean;
  loadOnClick?: boolean;
}

const { 
  enableGA = true,
  enableGTM = false,
  loadOnScroll = true,
  loadOnClick = true
} = Astro.props;
---

<script define:vars={{ enableGA, enableGTM, loadOnScroll, loadOnClick, SITE_CONFIG }}>
  // Lazy Analytics Loader
  let analyticsLoaded = false;
  
  function loadAnalytics() {
    if (analyticsLoaded) return;
    analyticsLoaded = true;
    
    // Load Google Analytics
    if (enableGA && SITE_CONFIG.googleAnalytics) {
      const gaScript = document.createElement('script');
      gaScript.async = true;
      gaScript.src = `https://www.googletagmanager.com/gtag/js?id=${SITE_CONFIG.googleAnalytics}`;
      document.head.appendChild(gaScript);
      
      gaScript.onload = () => {
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', SITE_CONFIG.googleAnalytics, {
          anonymize_ip: true,
          allow_google_signals: false
        });
        
        // Track page view
        gtag('event', 'page_view', {
          page_title: document.title,
          page_location: window.location.href,
          page_path: window.location.pathname
        });
      };
    }
    
    // Load GTM if enabled
    if (enableGTM && SITE_CONFIG.gtm?.enabled && SITE_CONFIG.gtm?.id) {
      const gtmScript = document.createElement('script');
      gtmScript.innerHTML = `
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','${SITE_CONFIG.gtm.id}');
      `;
      document.head.appendChild(gtmScript);
    }
    
    console.log('Analytics loaded lazily');
  }
  
  // Load on user interaction
  const events = [];
  
  if (loadOnScroll) {
    events.push('scroll');
  }
  
  if (loadOnClick) {
    events.push('click', 'touchstart');
  }
  
  // Also load after 3 seconds if no interaction
  const timeoutId = setTimeout(loadAnalytics, 3000);
  
  // Load on first user interaction
  const loadOnInteraction = () => {
    clearTimeout(timeoutId);
    loadAnalytics();
    
    // Remove event listeners
    events.forEach(event => {
      document.removeEventListener(event, loadOnInteraction);
    });
  };
  
  // Add event listeners
  events.forEach(event => {
    document.addEventListener(event, loadOnInteraction, { once: true, passive: true });
  });
</script>

<!-- Minimal noscript fallback -->
<noscript>
  {enableGA && SITE_CONFIG.googleAnalytics && (
    <img src={`https://www.googletagmanager.com/ns.html?id=${SITE_CONFIG.googleAnalytics}`} 
         height="0" width="0" style="display:none;visibility:hidden" />
  )}
</noscript>
