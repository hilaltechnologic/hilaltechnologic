---
// Content Enhancer Component
// Menambah meaningful text content untuk meningkatkan text-to-HTML ratio

interface Props {
  type?: 'article' | 'page' | 'homepage';
  title?: string;
  description?: string;
  keywords?: string[];
}

const { 
  type = 'page', 
  title = '',
  description = '',
  keywords = []
} = Astro.props;

// Generate additional content based on type
const generateContent = (type: string) => {
  switch(type) {
    case 'homepage':
      return {
        intro: "Hilal Technologic adalah platform blog teknologi terdepan yang menyajikan konten berkualitas tinggi tentang web development, programming, dan teknologi terbaru. Kami berkomitmen untuk memberikan tutorial praktis, tips berguna, dan insight mendalam untuk developer Indonesia.",
        features: [
          "Tutorial web development lengkap dengan contoh kode praktis",
          "Pembahasan framework modern seperti Astro, React, dan Vue",
          "Tips optimasi website untuk performa dan SEO terbaik",
          "Update teknologi terbaru dan trend development",
          "Panduan step-by-step untuk pemula hingga advanced"
        ],
        benefits: "Dengan mengikuti blog kami, Anda akan mendapatkan pengetahuan praktis yang dapat langsung diterapkan dalam project development Anda. Semua artikel ditulis berdasarkan pengalaman nyata dan best practices industry."
      };
    case 'article':
      return {
        intro: "Artikel ini memberikan panduan komprehensif dan praktis yang dapat membantu Anda memahami konsep dengan lebih baik.",
        features: [
          "Penjelasan detail dengan contoh kode yang dapat dijalankan",
          "Best practices yang direkomendasikan oleh industry",
          "Tips troubleshooting untuk masalah umum",
          "Resource tambahan untuk pembelajaran lanjutan"
        ]
      };
    default:
      return {
        intro: "Halaman ini menyediakan informasi lengkap dan terstruktur untuk membantu Anda menemukan apa yang Anda cari.",
        features: []
      };
  }
};

const content = generateContent(type);
---

<div class="content-enhancer">
  {content.intro && (
    <div class="intro-text">
      <p>{content.intro}</p>
    </div>
  )}
  
  {content.features && content.features.length > 0 && (
    <div class="features-text">
      <h3>Yang Akan Anda Dapatkan:</h3>
      <ul>
        {content.features.map((feature) => (
          <li>{feature}</li>
        ))}
      </ul>
    </div>
  )}
  
  {content.benefits && (
    <div class="benefits-text">
      <p>{content.benefits}</p>
    </div>
  )}
  
  {keywords.length > 0 && (
    <div class="keywords-text">
      <p>
        Topik yang dibahas meliputi: {keywords.join(', ')}. 
        Semua materi disajikan dengan bahasa yang mudah dipahami dan contoh praktis yang relevan.
      </p>
    </div>
  )}
  
  <div class="additional-context">
    <p>
      Hilal Technologic selalu mengutamakan kualitas konten dan keakuratan informasi. 
      Setiap artikel melalui proses review untuk memastikan informasi yang disajikan 
      up-to-date dan sesuai dengan standar industry terkini.
    </p>
  </div>
</div>

<style>
  .content-enhancer {
    @apply space-y-4 text-gray-800 dark:text-gray-200;
  }
  
  .intro-text p {
    @apply text-lg leading-relaxed;
  }
  
  .features-text h3 {
    @apply font-semibold text-gray-900 dark:text-white mb-2;
  }
  
  .features-text ul {
    @apply list-disc list-inside space-y-1 ml-4;
  }
  
  .benefits-text p {
    @apply text-base leading-relaxed;
  }
  
  .keywords-text p {
    @apply text-sm text-gray-700 dark:text-gray-300;
  }
  
  .additional-context p {
    @apply text-sm text-gray-600 dark:text-gray-400 italic;
  }
</style>
