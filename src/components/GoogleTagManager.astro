---
// Google Tag Manager Component
// Supports consent mode and privacy-first configuration

export interface Props {
  gtmId: string;
  enableInDevelopment?: boolean;
  dataLayer?: Record<string, any>;
}

const { 
  gtmId, 
  enableInDevelopment = false,
  dataLayer = {}
} = Astro.props;

// Check if we should load GTM
const isDevelopment = import.meta.env.DEV;
const shouldLoadGTM = !isDevelopment || enableInDevelopment;

// Default dataLayer with consent mode
const defaultDataLayer = {
  'gtm.start': new Date().getTime(),
  event: 'gtm.js',
  // Consent mode defaults (denied until user consents)
  'gtag_consent_mode': {
    'ad_storage': 'denied',
    'analytics_storage': 'denied',
    'functionality_storage': 'denied',
    'personalization_storage': 'denied',
    'security_storage': 'granted',
    'wait_for_update': 500
  },
  // Custom data
  ...dataLayer
};
---

{shouldLoadGTM && (
  <>
    <!-- Google Tag Manager - Head Script -->
    <script is:inline define:vars={{ gtmId, defaultDataLayer }}>
      // Initialize dataLayer
      window.dataLayer = window.dataLayer || [];
      
      // Push default configuration
      window.dataLayer.push(defaultDataLayer);
      
      // GTM Script
      (function(w,d,s,l,i){
        w[l]=w[l]||[];
        w[l].push({'gtm.start': new Date().getTime(),event:'gtm.js'});
        var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';
        j.async=true;
        j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
        f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer', gtmId);
      
      // GTM Helper Functions
      window.gtmHelper = {
        // Push events to dataLayer
        push: function(data) {
          if (window.dataLayer) {
            window.dataLayer.push(data);
          }
        },
        
        // Update consent
        updateConsent: function(consentSettings) {
          window.dataLayer.push({
            event: 'consent_update',
            ...consentSettings
          });
        },
        
        // Grant all consent
        grantConsent: function() {
          window.dataLayer.push({
            event: 'consent_update',
            ad_storage: 'granted',
            analytics_storage: 'granted',
            functionality_storage: 'granted',
            personalization_storage: 'granted'
          });
        },
        
        // Deny all consent
        denyConsent: function() {
          window.dataLayer.push({
            event: 'consent_update',
            ad_storage: 'denied',
            analytics_storage: 'denied',
            functionality_storage: 'denied',
            personalization_storage: 'denied'
          });
        },
        
        // Track custom events
        trackEvent: function(eventName, parameters = {}) {
          window.dataLayer.push({
            event: eventName,
            ...parameters
          });
        },
        
        // Track page views
        trackPageView: function(pagePath, pageTitle) {
          window.dataLayer.push({
            event: 'page_view',
            page_path: pagePath,
            page_title: pageTitle,
            page_location: window.location.href
          });
        },
        
        // E-commerce tracking
        trackPurchase: function(transactionData) {
          window.dataLayer.push({
            event: 'purchase',
            ecommerce: transactionData
          });
        },
        
        // User engagement
        trackEngagement: function(engagementData) {
          window.dataLayer.push({
            event: 'user_engagement',
            ...engagementData
          });
        }
      };
      
      // Auto-track page views for SPA navigation
      let currentPath = window.location.pathname;
      
      // Initialize navigation tracking when DOM is ready
      function initNavigationTracking() {
        if (document.body) {
          // Listen for navigation changes
          const observer = new MutationObserver(function() {
            if (window.location.pathname !== currentPath) {
              currentPath = window.location.pathname;
              window.gtmHelper.trackPageView(currentPath, document.title);
            }
          });
          
          // Start observing
          try {
            observer.observe(document.body, {
              childList: true,
              subtree: true
            });
            console.log('GTM navigation tracking initialized');
          } catch (error) {
            console.warn('GTM navigation tracking failed to initialize:', error);
          }
        } else {
          // Retry if body is not ready
          setTimeout(initNavigationTracking, 100);
        }
      }
      
      // Initialize when DOM is ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initNavigationTracking);
      } else {
        initNavigationTracking();
      }
    </script>
  </>
)}

<!-- GTM NoScript Fallback (will be added to body) -->
<script is:inline define:vars={{ gtmId, shouldLoadGTM }}>
  if (shouldLoadGTM) {
    // Add noscript fallback to body when DOM is ready
    document.addEventListener('DOMContentLoaded', function() {
      if (!document.getElementById('gtm-noscript')) {
        const noscript = document.createElement('noscript');
        noscript.id = 'gtm-noscript';
        noscript.innerHTML = `<iframe src="https://www.googletagmanager.com/ns.html?id=${gtmId}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`;
        document.body.insertBefore(noscript, document.body.firstChild);
      }
    });
  }
</script>

<style>
  /* Hide GTM noscript iframe */
  #gtm-noscript iframe {
    display: none !important;
    visibility: hidden !important;
  }
</style>
