---
// GTM Events Component
// Handles automatic event tracking for common user interactions

export interface Props {
  enableAutoTracking?: boolean;
  trackScrollDepth?: boolean;
  trackOutboundLinks?: boolean;
  trackFileDownloads?: boolean;
  trackFormSubmissions?: boolean;
  trackVideoEngagement?: boolean;
  customEvents?: string[];
}

const {
  enableAutoTracking = true,
  trackScrollDepth = true,
  trackOutboundLinks = true,
  trackFileDownloads = true,
  trackFormSubmissions = true,
  trackVideoEngagement = true,
  customEvents = []
} = Astro.props;
---

{enableAutoTracking && (
  <script is:inline define:vars={{ 
    trackScrollDepth, 
    trackOutboundLinks, 
    trackFileDownloads, 
    trackFormSubmissions,
    trackVideoEngagement,
    customEvents 
  }}>
    // Wait for GTM to be available
    function waitForGTM(callback) {
      if (window.gtmHelper) {
        callback();
      } else {
        setTimeout(() => waitForGTM(callback), 100);
      }
    }
    
    waitForGTM(function() {
      // Scroll Depth Tracking
      if (trackScrollDepth) {
        let scrollDepthMarks = [25, 50, 75, 90, 100];
        let scrollDepthTriggered = [];
        
        function trackScrollDepth() {
          const scrollPercent = Math.round(
            (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100
          );
          
          scrollDepthMarks.forEach(mark => {
            if (scrollPercent >= mark && !scrollDepthTriggered.includes(mark)) {
              scrollDepthTriggered.push(mark);
              window.gtmHelper.trackEvent('scroll_depth', {
                scroll_depth: mark,
                page_path: window.location.pathname,
                page_title: document.title
              });
            }
          });
        }
        
        let scrollTimeout;
        window.addEventListener('scroll', function() {
          clearTimeout(scrollTimeout);
          scrollTimeout = setTimeout(trackScrollDepth, 100);
        });
      }
      
      // Outbound Link Tracking
      if (trackOutboundLinks) {
        document.addEventListener('click', function(e) {
          const link = e.target.closest('a');
          if (link && link.href) {
            const url = new URL(link.href, window.location.origin);
            const isOutbound = url.hostname !== window.location.hostname;
            
            if (isOutbound) {
              window.gtmHelper.trackEvent('click_outbound_link', {
                link_url: link.href,
                link_text: link.textContent.trim(),
                link_domain: url.hostname,
                source_page: window.location.pathname
              });
            }
          }
        });
      }
      
      // File Download Tracking
      if (trackFileDownloads) {
        const downloadExtensions = [
          'pdf', 'doc', 'docx', 'xls', 'xlsx', 'ppt', 'pptx',
          'zip', 'rar', '7z', 'tar', 'gz',
          'mp3', 'wav', 'mp4', 'avi', 'mov',
          'jpg', 'jpeg', 'png', 'gif', 'svg',
          'txt', 'csv', 'json', 'xml'
        ];
        
        document.addEventListener('click', function(e) {
          const link = e.target.closest('a');
          if (link && link.href) {
            const url = new URL(link.href, window.location.origin);
            const extension = url.pathname.split('.').pop()?.toLowerCase();
            
            if (extension && downloadExtensions.includes(extension)) {
              window.gtmHelper.trackEvent('file_download', {
                file_url: link.href,
                file_name: url.pathname.split('/').pop(),
                file_extension: extension,
                link_text: link.textContent.trim(),
                source_page: window.location.pathname
              });
            }
          }
        });
      }
      
      // Form Submission Tracking
      if (trackFormSubmissions) {
        document.addEventListener('submit', function(e) {
          const form = e.target;
          if (form.tagName === 'FORM') {
            const formData = new FormData(form);
            const formFields = Array.from(formData.keys());
            
            window.gtmHelper.trackEvent('form_submit', {
              form_id: form.id || 'unknown',
              form_name: form.name || 'unknown',
              form_fields: formFields.join(','),
              form_action: form.action || window.location.href,
              source_page: window.location.pathname
            });
          }
        });
      }
      
      // Video Engagement Tracking
      if (trackVideoEngagement) {
        document.addEventListener('play', function(e) {
          if (e.target.tagName === 'VIDEO') {
            window.gtmHelper.trackEvent('video_play', {
              video_title: e.target.title || 'Unknown Video',
              video_url: e.target.currentSrc || e.target.src,
              video_duration: e.target.duration,
              source_page: window.location.pathname
            });
          }
        }, true);
        
        document.addEventListener('pause', function(e) {
          if (e.target.tagName === 'VIDEO') {
            window.gtmHelper.trackEvent('video_pause', {
              video_title: e.target.title || 'Unknown Video',
              video_url: e.target.currentSrc || e.target.src,
              video_current_time: e.target.currentTime,
              video_duration: e.target.duration,
              source_page: window.location.pathname
            });
          }
        }, true);
        
        document.addEventListener('ended', function(e) {
          if (e.target.tagName === 'VIDEO') {
            window.gtmHelper.trackEvent('video_complete', {
              video_title: e.target.title || 'Unknown Video',
              video_url: e.target.currentSrc || e.target.src,
              video_duration: e.target.duration,
              source_page: window.location.pathname
            });
          }
        }, true);
      }
      
      // Search Tracking (integrate with existing search)
      const searchInput = document.querySelector('[data-search-input]');
      if (searchInput) {
        let searchTimeout;
        searchInput.addEventListener('input', function(e) {
          clearTimeout(searchTimeout);
          searchTimeout = setTimeout(() => {
            if (e.target.value.length >= 3) {
              window.gtmHelper.trackEvent('search', {
                search_term: e.target.value,
                source_page: window.location.pathname
              });
            }
          }, 1000);
        });
      }
      
      // Button Click Tracking
      document.addEventListener('click', function(e) {
        const button = e.target.closest('button, [role="button"], .btn');
        if (button) {
          window.gtmHelper.trackEvent('button_click', {
            button_text: button.textContent.trim(),
            button_id: button.id || 'unknown',
            button_class: button.className,
            source_page: window.location.pathname
          });
        }
      });
      
      // Page Engagement Time
      let startTime = Date.now();
      let isActive = true;
      let totalEngagementTime = 0;
      
      // Track when user becomes active/inactive
      document.addEventListener('visibilitychange', function() {
        if (document.hidden) {
          if (isActive) {
            totalEngagementTime += Date.now() - startTime;
            isActive = false;
          }
        } else {
          startTime = Date.now();
          isActive = true;
        }
      });
      
      // Send engagement time before page unload
      window.addEventListener('beforeunload', function() {
        if (isActive) {
          totalEngagementTime += Date.now() - startTime;
        }
        
        if (totalEngagementTime > 0) {
          window.gtmHelper.trackEvent('page_engagement', {
            engagement_time: Math.round(totalEngagementTime / 1000), // in seconds
            page_path: window.location.pathname,
            page_title: document.title
          });
        }
      });
      
      // Custom Events
      if (customEvents && customEvents.length > 0) {
        customEvents.forEach(eventSelector => {
          const elements = document.querySelectorAll(eventSelector);
          elements.forEach(element => {
            element.addEventListener('click', function() {
              window.gtmHelper.trackEvent('custom_interaction', {
                element_selector: eventSelector,
                element_text: element.textContent.trim(),
                element_id: element.id || 'unknown',
                source_page: window.location.pathname
              });
            });
          });
        });
      }
      
      // Error Tracking
      window.addEventListener('error', function(e) {
        window.gtmHelper.trackEvent('javascript_error', {
          error_message: e.message,
          error_filename: e.filename,
          error_line: e.lineno,
          error_column: e.colno,
          source_page: window.location.pathname
        });
      });
      
      // Performance Tracking
      window.addEventListener('load', function() {
        setTimeout(() => {
          const navigation = performance.getEntriesByType('navigation')[0];
          if (navigation) {
            window.gtmHelper.trackEvent('page_performance', {
              page_load_time: Math.round(navigation.loadEventEnd - navigation.fetchStart),
              dom_content_loaded: Math.round(navigation.domContentLoadedEventEnd - navigation.fetchStart),
              first_byte: Math.round(navigation.responseStart - navigation.fetchStart),
              source_page: window.location.pathname
            });
          }
        }, 1000);
      });
      
      // Core Web Vitals (if supported)
      if ('web-vital' in window) {
        import('web-vitals').then(({ getCLS, getFID, getFCP, getLCP, getTTFB }) => {
          getCLS((metric) => {
            window.gtmHelper.trackEvent('web_vital', {
              metric_name: 'CLS',
              metric_value: metric.value,
              metric_rating: metric.rating,
              source_page: window.location.pathname
            });
          });
          
          getFID((metric) => {
            window.gtmHelper.trackEvent('web_vital', {
              metric_name: 'FID',
              metric_value: metric.value,
              metric_rating: metric.rating,
              source_page: window.location.pathname
            });
          });
          
          getFCP((metric) => {
            window.gtmHelper.trackEvent('web_vital', {
              metric_name: 'FCP',
              metric_value: metric.value,
              metric_rating: metric.rating,
              source_page: window.location.pathname
            });
          });
          
          getLCP((metric) => {
            window.gtmHelper.trackEvent('web_vital', {
              metric_name: 'LCP',
              metric_value: metric.value,
              metric_rating: metric.rating,
              source_page: window.location.pathname
            });
          });
          
          getTTFB((metric) => {
            window.gtmHelper.trackEvent('web_vital', {
              metric_name: 'TTFB',
              metric_value: metric.value,
              metric_rating: metric.rating,
              source_page: window.location.pathname
            });
          });
        }).catch(() => {
          // web-vitals not available, skip
        });
      }
    });
  </script>
)}
